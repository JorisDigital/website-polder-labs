---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<h1>Polder Labs</h1>
		<p>The website is live and running on Azure Static Web Apps.</p>
		<p>Content and branding are being prepared for the first public version.</p>
	</main>
</Layout>

<style>
	main {
		min-height: 100vh;
		display: grid;
		place-content: center;
		gap: 0.75rem;
		padding: 2rem;
		text-align: center;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 6vw, 4rem);
	}

	p {
		margin: 0;
		font-size: 1.05rem;
		color: #cbd5e1;
	}
</style>
